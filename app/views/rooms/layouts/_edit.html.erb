<% @page_title = "Edit settings for #{room.name}" %>

<% content_for :nav do %>
  <div class="flex-item-justify-start">
    <%= link_back_to_last_room_visited %>
  </div>
<% end %>

<section class="panel txt-align-center room-info-card" style="view-transition-name: edit-room-<%= room.id %>">
  <div class="room-info-card__meta">
    <strong><%= room_display_name(room) %></strong>
    <div class="txt-small room-info-card__subtitle">
      <span><%= room.users.count %> members</span>
      <% if room.direct? %>
        <% online_members = room.direct_peers_excluding(Current.user).count { |peer| user_online?(peer) } %>
        <% if online_members.positive? %>
          · <span><%= online_members %> online</span>
        <% end %>
      <% end %>
    </div>
  </div>
  <%= yield %>
</section>

<% if Current.user.can_administer?(@room) %>
  <section class="panel txt-align-center">
    <%= button_to_delete_room room %>
  </section>
<% end %>
