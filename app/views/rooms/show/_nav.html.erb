<% content_for :nav do %>
  <%= account_logo_tag if Current.account&.logo&.attached? %>

  <%= link_to room_info_path(room), class: "btn btn--reversed btn--faux room--current" do %>
    <h1 class="room__contents txt-medium overflow-ellipsis">
      <% if room.direct? %>
        <span class="for-screen-reader">Direct message with</span>
      <% end %>

      <%= room.direct? ? room_display_name(room) : "##{room_display_name(room)}" %>
    </h1>
  <% end %>

  <%= tag.details class: "position-relative room-nav-dropdown", style: "inline-size: var(--btn-size); min-inline-size: var(--btn-size);",
      data: { controller: "popup", action: "keydown.esc->popup#close toggle->popup#toggle click@document->popup#closeOnClickOutside", popup_orientation_top_class: "popup-orientation-top" } do %>
    <summary class="btn room-nav-dropdown__trigger" style="block-size: var(--btn-size); inline-size: var(--btn-size); min-inline-size: var(--btn-size);">
      <%= image_tag "menu-dots-horizontal.svg", size: 20, aria: { hidden: "true" } %>
      <span class="for-screen-reader">Room actions</span>
    </summary>

    <div class="room-nav-menu shadow" data-popup-target="menu" style="position: absolute; inset: calc(var(--btn-size) + 0.4rem) 0 auto auto; min-inline-size: 11.5rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 0.75rem; padding: 0.4rem; z-index: 12;">
      <div class="room-nav-menu__section-label" style="font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.45rem; text-transform: uppercase; opacity: 0.8;">Navigate</div>
      <%= link_to room_path(room, tab: "messages"), class: class_names("room-nav-menu__item", "room-nav-menu__item--active": @active_room_tab == "messages"), style: "display: flex; align-items: center; column-gap: 0.5rem; padding: 0.48rem 0.52rem; border-radius: 0.45rem; text-decoration: none; color: var(--color-text); pointer-events: auto; #{@active_room_tab == "messages" ? "background: color-mix(in oklab, var(--color-border), var(--color-bg) 32%);" : ""}" do %>
        <%= image_tag "messages.svg", size: 18, class: "colorize--black", aria: { hidden: "true" } %>
        Messages
      <% end %>
      <%= link_to room_path(room, tab: "files"), class: class_names("room-nav-menu__item", "room-nav-menu__item--active": @active_room_tab == "files"), style: "display: flex; align-items: center; column-gap: 0.5rem; padding: 0.48rem 0.52rem; border-radius: 0.45rem; text-decoration: none; color: var(--color-text); pointer-events: auto; #{@active_room_tab == "files" ? "background: color-mix(in oklab, var(--color-border), var(--color-bg) 32%);" : ""}" do %>
        <%= image_tag "attachment.svg", size: 18, class: "colorize--black", aria: { hidden: "true" } %>
        Files
      <% end %>
      <hr class="room-nav-menu__divider" style="border: 0; border-top: 1px solid var(--color-border); margin: 0.25rem 0.15rem;">
      <div class="room-nav-menu__section-label" style="font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.45rem; text-transform: uppercase; opacity: 0.8;">Room</div>
      <%= link_to room_info_path(room), class: "room-nav-menu__item", style: "display: flex; align-items: center; column-gap: 0.5rem; padding: 0.48rem 0.52rem; border-radius: 0.45rem; text-decoration: none; color: var(--color-text); pointer-events: auto;" do %>
        <%= image_tag "settings.svg", size: 18, class: "colorize--black", aria: { hidden: "true" } %>
        Room info
      <% end %>
    </div>
  <% end %>

  <%= render "rooms/involvements/bell", room: room %>
<% end %>
