<% content_for :nav do %>
  <%= account_logo_tag if Current.account&.logo&.attached? %>

  <%= link_to room_info_path(room), class: "btn btn--reversed btn--faux room--current" do %>
    <h1 class="room__contents txt-medium overflow-ellipsis">
      <% if room.direct? %>
        <span class="for-screen-reader">Direct message with</span>
      <% end %>

      <%= room.direct? ? room_display_name(room) : "##{room_display_name(room)}" %>
    </h1>
  <% end %>

  <%= tag.details class: "position-relative room-nav-dropdown", style: "inline-size: var(--btn-size); min-inline-size: var(--btn-size);",
      data: { controller: "popup", action: "keydown.esc->popup#close toggle->popup#toggle click@document->popup#closeOnClickOutside", popup_orientation_top_class: "popup-orientation-top" } do %>
    <summary class="btn room-nav-dropdown__trigger" style="block-size: var(--btn-size); inline-size: var(--btn-size); min-inline-size: var(--btn-size);">
      <%= image_tag "menu-dots-horizontal.svg", size: 20, aria: { hidden: "true" } %>
      <span class="for-screen-reader">Room actions</span>
    </summary>

    <div class="room-nav-menu shadow" data-popup-target="menu">
      <div class="room-nav-menu__section-label" style="font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.45rem; text-transform: uppercase; opacity: 0.8;">Navigate</div>
      <%= link_to room_path(room, tab: "messages"), class: class_names("room-nav-menu__item", "room-nav-menu__item--active": @active_room_tab == "messages") do %>
        <%= image_tag "messages.svg", size: 18, class: "room-nav-menu__icon", aria: { hidden: "true" } %>
        Messages
      <% end %>
      <%= link_to room_path(room, tab: "files"), class: class_names("room-nav-menu__item", "room-nav-menu__item--active": @active_room_tab == "files") do %>
        <%= image_tag "attachment.svg", size: 18, class: "room-nav-menu__icon", aria: { hidden: "true" } %>
        Files
      <% end %>
      <hr class="room-nav-menu__divider" style="border: 0; border-top: 1px solid var(--color-border); margin: 0.25rem 0.15rem;">
      <div class="room-nav-menu__section-label" style="font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.45rem; text-transform: uppercase; opacity: 0.8;">Room</div>
      <%= link_to room_info_path(room), class: "room-nav-menu__item" do %>
        <%= image_tag "settings.svg", size: 18, class: "room-nav-menu__icon", aria: { hidden: "true" } %>
        Room info
      <% end %>
    </div>
  <% end %>

  <button type="button" class="btn" title="Start a call"
      onclick="var t=document.querySelector('#composer trix-editor');if(t){t.editor.setSelectedRange([0,t.editor.getDocument().toString().length]);t.editor.deleteInDirection('forward');t.editor.insertHTML('/meet');document.querySelector('#composer').requestSubmit()}">
    <img src="data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M21.384 17.752a2.108 2.108 0 0 1-.65 1.64l-2.257 2.22a2.61 2.61 0 0 1-1.89.78c-.09 0-.18 0-.27-.01a24.6 24.6 0 0 1-10.71-4.37 24.17 24.17 0 0 1-5.08-5.08A24.42 24.42 0 0 1 .156 2.286a2.41 2.41 0 0 1 .75-2.15L3.126.136a2.08 2.08 0 0 1 1.66-.65 2.13 2.13 0 0 1 1.53.91l2.83 3.93a2.12 2.12 0 0 1-.36 2.79l-1.37 1.13a15.43 15.43 0 0 0 2.63 3.57 15.57 15.57 0 0 0 3.57 2.63l1.13-1.37a2.12 2.12 0 0 1 2.79-.36l3.93 2.83a2.12 2.12 0 0 1 .91 1.55v.59z'/%3E%3C/svg%3E" width="20" height="20" aria-hidden="true">
    <span class="for-screen-reader">Start a call</span>
  </button>

  <%= render "rooms/involvements/bell", room: room %>
<% end %>
