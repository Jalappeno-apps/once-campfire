<% room, unread =
     if (m = local_assigns[:membership])
      [ m.room, m.unread? ]
     else
       r = local_assigns[:room]
      [ r, local_assigns.fetch(:unread, false) ]
     end %>
<% list_data = { sidebar_active_room_target: "row" }
   if room.direct?
     list_data[:sorted_list_number] = room.updated_at.to_fs(:epoch)
   else
     list_data[:sorted_list_name] = room.name
   end %>
<% direct_peers = room.direct? ? room.direct_peers_excluding(Current.user).reject(&:bot?) : [] %>
<% peer_online = room.direct? && direct_peers.any? { |peer| user_online?(peer) } %>
<% direct_presence_title = room.direct? ? room_direct_presence_title(room) : "" %>
<%= link_to_room room,
      id: dom_id(room, :list),
      data: list_data,
      style: "--column-gap: 0.5em",
      class: [ "sidebar-row align-center gap room btn txt-nowrap", "unread": unread ] do %>
  <% if room.direct? %>
    <span class="sidebar-row__prefix sidebar-row__prefix--dm <%= "sidebar-row__prefix--dm-online" if peer_online %>"
          aria-hidden="true"
          title="<%= direct_presence_title %>"></span>
    <span class="sidebar-row__label txt-nowrap overflow-ellipsis">
      <span class="for-screen-reader">Direct message with</span>
      <%= room_display_name(room) %>
    </span>
  <% else %>
    <span class="sidebar-row__prefix" aria-hidden="true">#</span>
    <span class="sidebar-row__label txt-nowrap overflow-ellipsis"><%= room.name %></span>
  <% end %>
  <span class="sidebar-row__unread-dot" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 8" width="8" height="8" focusable="false" aria-hidden="true"><circle cx="4" cy="4" r="4" fill="none"/></svg>
  </span>
<% end %>