<% room, unread, viewer_id =
     if (m = local_assigns[:membership])
       [ m.room, m.unread?, m.user_id ]
     else
       r = local_assigns[:room]
       [ r, local_assigns.fetch(:unread, false), Current.user&.id ]
     end %>
<% list_data = { sidebar_active_room_target: "row" }
   if room.direct?
     list_data[:sorted_list_number] = room.updated_at.to_fs(:epoch)
   else
     list_data[:sorted_list_name] = room.name
   end %>
<% peer_active_in_room =
     room.direct? && viewer_id && room.memberships.reject { |m| m.user_id == viewer_id }.any?(&:connected?) %>
<%= link_to_room room,
      id: dom_id(room, :list),
      data: list_data,
      style: "--column-gap: 0.5em",
      class: [ "sidebar-row align-center gap room btn txt-nowrap", "unread": unread ] do %>
  <% if room.direct? %>
    <span class="sidebar-row__prefix sidebar-row__prefix--dm <%= "sidebar-row__prefix--dm-online" if peer_active_in_room %>"
          aria-hidden="true"
          title="<%= peer_active_in_room ? "Active in this chat" : "" %>"></span>
    <span class="sidebar-row__label txt-nowrap overflow-ellipsis">
      <span class="for-screen-reader">Direct message with</span>
      <%= room_display_name(room) %>
    </span>
  <% else %>
    <span class="sidebar-row__prefix" aria-hidden="true">#</span>
    <span class="sidebar-row__label txt-nowrap overflow-ellipsis"><%= room.name %></span>
  <% end %>
<% end %>
