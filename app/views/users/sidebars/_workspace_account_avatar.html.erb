<%# locals: (account:) %>
<% if account.id == Current.account.id %>
  <%= account_logo_tag %>
<% elsif account.logo.attached? %>
  <%= tag.figure image_tag(account.logo.variant(resize_to_limit: [512, 512]), alt: "Account logo", size: 300), class: "account-logo avatar" %>
<% else %>
  <%= tag.figure class: "account-logo avatar" do %>
    <span class="account-logo__initials"><%= workspace_initials(account.name) %></span>
  <% end %>
<% end %>
