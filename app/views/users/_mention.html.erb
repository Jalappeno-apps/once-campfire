<span class="mention mention--interactive"
      sgid="<%= user.attachable_sgid %>"
      data-controller="mention-card"
      data-action="mouseenter->mention-card#show mouseleave->mention-card#hide focusin->mention-card#show focusout->mention-card#hide">
  <%= link_to user_path(user), class: "mention__chip txt-undecorated" do %>
    <span class="mention__avatar" aria-hidden="true">
      <%= user_avatar_img_tag user, class: "mention__avatar-img" %>
    </span>
    <span class="mention__name">@<%= user.name %></span>
  <% end %>

  <div class="mention-card"
       role="dialog"
       aria-label="<%= user.name %> profile preview"
       hidden
       data-mention-card-target="card"
       style="padding: 0.75rem; box-sizing: border-box; overflow: hidden;">
    <div class="mention-card__header" style="display: grid; grid-template-columns: auto 1fr; gap: 0.58rem; align-items: center;">
      <span class="mention-card__avatar" aria-hidden="true" style="inline-size: 2.1rem; block-size: 2.1rem; border-radius: 999px; overflow: hidden; display: inline-flex;">
        <%= user_avatar_img_tag user, loading: :lazy, class: "mention-card__avatar-img", style: "inline-size: 100%; block-size: 100%; object-fit: cover;" %>
      </span>
      <div class="mention-card__identity">
        <strong class="overflow-ellipsis"><%= user.name %></strong>
        <span class="txt-small"><%= user_presence_label(user) %></span>
      </div>
    </div>
    <div class="mention-card__meta txt-small" style="padding-inline: 0.1rem;">
      <%= local_datetime_tag(Time.current, style: :time) %> local time
    </div>
    <div class="mention-card__actions" style="display: flex; flex-wrap: wrap; gap: 0.42rem; margin-block-start: 0.1rem;">
      <%= link_to user_path(user), class: "btn mention-card__action" do %>
        <%= image_tag "person.svg", size: 16, aria: { hidden: "true" } %>
        Profile
      <% end %>
      <%= link_to rooms_directs_path(user_ids: [ user.id ]), class: "btn mention-card__action", data: { turbo_method: :post } do %>
        <%= image_tag "messages.svg", size: 16, aria: { hidden: "true" } %>
        Message
      <% end %>
    </div>
  </div>
</span>
