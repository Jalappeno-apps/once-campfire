# Required
SECRET_KEY_BASE=replace_with_long_random_secret

# Optional but recommended for web push (browser notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Public URL users open in the browser (fixes calendar links / absolute URLs if Host behind the proxy is wrong)
# PUBLIC_APP_URL=https://chat.example.com

# SSL behavior (choose one)
SSL_DOMAIN=chat.example.com
# DISABLE_SSL=true

# Optional
SENTRY_DSN=
# Mobile native push delivery gateway (defaults to Expo endpoint if unset)
MOBILE_PUSH_DELIVERY_URL=

# Image reference used by docker-compose.prod.yml
CAMPFIRE_IMAGE=ghcr.io/jalappeno-apps/once-campfire:main
