{
  "name": "campfire-desktop",
  "version": "0.2.0",
  "description": "Campfire desktop client",
  "main": "main.js",
  "author": "Daiwick",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64 && rm -rf dist/win-x64-unpacked dist/win-arm64-unpacked dist/win-unpacked",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.daiwick.campfire-desktop",
    "productName": "Campfire",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "logo.png",
      "logo.ico"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "logo.png",
      "identity": null,
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "logo.ico",
      "target": ["portable"],
      "signingHashAlgorithms": null
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-store": "^8.0.0"
  }
}
